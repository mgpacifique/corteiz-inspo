<!DOCTYPE html>
<html class="supports-js" lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#ffffff">
  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
  {% else %}
    <link rel="shortcut icon" href="{{ 'favicon_cortez_4633eb91-8e93-4c3f-afd6-c13466468694_32x32.png' | asset_url }}" type="image/png">
  {% endif %}

  <title>
    {{ page_title }}
    {% if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif %}
    {% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}
    {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ 'featherlight.min.css' | asset_url | stylesheet_tag }}
  {{ 'featherlight.gallery.min.css' | asset_url | stylesheet_tag }}
  {{ 'theme.scss.css' | asset_url | stylesheet_tag }}

  <!-- Google Fonts -->
  <link href="//fonts.googleapis.com/css?family=Karla:400,700" rel="stylesheet" type="text/css" media="all">

  {{ content_for_header }}

  <script src="{{ 'jquery-1.11.0.min.js' | asset_url }}" type="text/javascript"></script>
  <script src="{{ 'modernizr.min.js' | asset_url }}" type="text/javascript"></script>
  <script src="{{ 'lazysizes.min.js' | asset_url }}" async="async"></script>

  <style>
    body {
      background-color: #ffffff !important;
      color: #000000 !important;
    }
    .site-header__logo img {
      filter: invert(1);
    }
    #HeaderLogo {
      filter: invert(1);
    }
    /* Any text inside header or links */
    a, .site-nav__link, .site-header__cart {
      color: #000000 !important;
    }
    .grid-view-item__title, .grid-view-item__meta {
      color: #000000 !important;
    }
    /* White background overrides */
    .template-index .site-header {
      background: #ffffff;
    }
  </style>

</head>

<body id="{{ page_title | handle }}" class="template-{{ template.name | handle }}">

  <a class="in-page-link visually-hidden skip-link" href="#MainContent">Skip to content</a>

  {% section 'header' %}

  <div class="site-wrapper">
    <main class="main-content" id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
  </div>

  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}" type="text/javascript"></script>
  <script src="{{ 'featherlight.min.js' | asset_url }}" type="text/javascript"></script>
  <script src="{{ 'featherlight.gallery.min.js' | asset_url }}" type="text/javascript"></script>

</body>
</html>
